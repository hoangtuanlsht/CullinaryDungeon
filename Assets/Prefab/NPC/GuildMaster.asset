  m_Script: {fileID: 11500000, guid: 27a319b28ee5cc14a850710e5d160ac0, type: 3}
  m_Name: GuildMaster
  m_EditorClassIdentifier: 
  npcName: GuildMaster
  npcPortrait: {fileID: -1320909188, guid: b3f751b7570564b409f285baad08e66d, type: 3}
  dialogueLines:
  - "Ch\xE0o m\u1EA1o hi\u1EC3m gi\u1EA3 tr\u1EBB tu\u1ED5i"
  - "N\u01A1i c\u1EADu \u0111ang \u0111\u1EE9ng \u0111\xE2y l\xE0 1 trong nh\u1EEFng
    h\u1EA7m ng\u1EE5c ch\u01B0a \u0111\u01B0\u1EE3c khai ph\xE1"
  - "Ch\u1EE9a \u0111\u1EA7y nh\u1EEFng lo\u1EA1i qu\xE1i nguy hi\u1EC3m"
  - "H\u1EA7m ng\u1EE5c \u0111\u01B0\u1EE3c c\u1EA5u tr\xFAc theo h\u01B0\u1EDBng
    \u0111\xE2m th\u1EB3ng xu\u1ED1ng l\xF2ng \u0111\u1EA5t v\u1EDBi nh\u1EEFng v\xF9ng
    k\xEC l\u1EA1"
  - "Tr\u01B0\u1EDBc \u0111\xE2y \u0111\xE3 c\xF3 r\u1EA5t nhi\u1EC1u k\u1EBB th\xE1ch
    th\u1EE9c quy\u1EC1n uy c\u1EE7a h\u1EA7m ng\u1EE5c nh\u01B0ng \u0111\u1EC1u
    th\u1EA5t b\u1EA1i"
  - "Tuy nhi\xEAn n\u1EBFu d\u1EC5 d\xE0ng chinh ph\u1EE5c th\xEC c\xF2n g\xEC l\xE0
    th\xFA v\u1ECB n\u1EEFa ch\u1EE9"
  - "T\xF4i ch\u1EC9 c\xF3 m\u1ED9t l\u1EDDi khuy\xEAn cho c\u1EADu l\xE0 \u0111\u1EEBng
    ti\u1EBFc vi\u1EC7c s\u1EED d\u1EE5ng b\xECnh m\xE1u v\xE0 c\xE1c th\u1EF1c ph\u1EA9m
    h\u1ED3i ph\u1EE5c"
  - "B\xE2y gi\u1EDD h\xE3y b\u1EAFt \u0111\u1EA7u h\xE0nh tr\xECnh c\u1EE7a m\xECnh
    \u0111i"
  - "Ch\xFAc may m\u1EAFn m\u1EA1o hi\u1EC3m gi\u1EA3 tr\u1EBB tu\u1ED5i"
